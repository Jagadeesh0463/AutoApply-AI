# Copy this file to .env and fill in your values
# Never commit .env to git

# Groq API (free tier) — get key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Gmail OAuth 2.0 — set up at https://console.cloud.google.com
# After creating OAuth credentials, download credentials.json and place it in backend/
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8000/auth/callback

# App settings
DAILY_SEND_CAP=10
ENV=development
